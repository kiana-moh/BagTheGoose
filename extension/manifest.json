{
  "manifest_version": 3,
  "name": "BagTheGoose",
  "version": "0.1.0",
  "description": "AI-powered internship discovery for Waterloo students",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/jobs/*"],
      "js": ["src/content.js"]
    }
  ],
  "action": {
    "default_title": "BagTheGoose"
  }
}