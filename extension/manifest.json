{
  "manifest_version": 3,
  "name": "BagTheGoose",
  "version": "0.1.0",
  "description": "Deterministic LinkedIn job extraction for BagTheGoose",
  "permissions": [
    "storage",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "http://127.0.0.1:8000/*",
    "https://api.bagthegoose.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "https://bagthegoose.com/*",
      "https://www.bagthegoose.com/*",
      "http://localhost:3000/*",
      "http://127.0.0.1:3000/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "BagTheGoose",
    "default_popup": "popup.html"
  }
}
